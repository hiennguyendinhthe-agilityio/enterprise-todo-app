{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        // ─── Enterprise Todo App ─────────────────────────────────────────────
        {
            "name": "🟢 Todo — Dev (iOS Simulator)",
            "request": "launch",
            "type": "dart",
            "deviceId": "apple_ios_simulator",
            "program": "lib/main_enterprise_todo.dart",
            "args": [
                "--dart-define-from-file=env/dev.json",
                "--flavor=dev"
            ]
        },
        {
            "name": "🟢 Todo — Dev (macOS)",
            "request": "launch",
            "type": "dart",
            "deviceId": "macos",
            "program": "lib/main_enterprise_todo.dart",
            "args": [
                "--dart-define-from-file=env/dev.json"
            ]
        },
        {
            "name": "🟢 Todo — Dev (Chrome)",
            "request": "launch",
            "type": "dart",
            "deviceId": "chrome",
            "program": "lib/main_enterprise_todo.dart",
            "args": [
                "--dart-define-from-file=env/dev.json",
                "--flavor=dev"
            ]
        },
        {
            "name": "🟡 Todo — Staging",
            "request": "launch",
            "type": "dart",
            "deviceId": "apple_ios_simulator",
            "program": "lib/main_enterprise_todo.dart",
            "args": [
                "--dart-define-from-file=env/staging.json",
                "--flavor=staging"
            ]
        },
        {
            "name": "🔴 Todo — Production",
            "request": "launch",
            "type": "dart",
            "deviceId": "apple_ios_simulator",
            "program": "lib/main_enterprise_todo.dart",
            "flutterMode": "release",
            "args": [
                "--dart-define-from-file=env/prod.json",
                "--flavor=prod"
            ]
        },
        // ─── Default Flutter configs ────────────────────────────────────────
        {
            "name": "flutter_application_2",
            "request": "launch",
            "type": "dart",
            "deviceId": "apple_ios_simulator",
            "program": "lib/main_enterprise_todo.dart",
            "args": [
                "--dart-define-from-file=env/dev.json",
                "--flavor=dev"
            ]
        },
        {
            "name": "flutter_application_2 (profile mode)",
            "request": "launch",
            "type": "dart",
            "deviceId": "apple_ios_simulator",
            "program": "lib/main_enterprise_todo.dart",
            "flutterMode": "profile",
            "args": [
                "--dart-define-from-file=env/dev.json",
                "--flavor=dev"
            ]
        },
        {
            "name": "flutter_application_2 (release mode)",
            "request": "launch",
            "type": "dart",
            "deviceId": "apple_ios_simulator",
            "program": "lib/main_enterprise_todo.dart",
            "flutterMode": "release",
            "args": [
                "--dart-define-from-file=env/prod.json",
                "--flavor=prod"
            ]
        }
    ]
}