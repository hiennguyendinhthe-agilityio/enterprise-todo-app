env/dev.json
env/staging.json
env/prod.json
# Legacy .env files
.env
.env.*
# Android keystore
*.keystore
*.jks
android/app/release.keystore
# iOS certs
*.p12
*.mobileprovision
# Obfuscation debug info (generated at build time)
debug-info/

